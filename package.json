{
  "name": "@crazygiscool/cap",
  "version": "1.2.0",
  "description": "The Central Archive Protocol core library for lore documentation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crawler": {
      "import": "./dist/crawler/index.js",
      "types": "./dist/crawler/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs/PLAN.md",
    "docs/QUICKSTART.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crazygiscool/CAP.git"
  },
  "keywords": [
    "documentation",
    "mongodb",
    "typescript",
    "lore"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Crazygiscool/CAP/issues"
  },
  "homepage": "https://github.com/Crazygiscool/CAP#readme",
  "peerDependencies": {
    "mongodb": "^6.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^2.1.9",
    "mongodb": "^6.5.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9",
    "zod": "^3.22.4"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  }
}
